# Variaveis de Ambiente — Laert Costa Studio
# Copie este arquivo para .env.local e preencha os valores reais.
# NUNCA commite o .env.local no repositorio.

# -----------------------------------------------
# Supabase
# -----------------------------------------------
# URL do seu projeto Supabase (encontrar em: Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co

# Chave publica anonima (encontrar em: Project Settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Chave de servico (encontrar em: Project Settings > API)
# ATENCAO: NUNCA use esta chave em variaveis NEXT_PUBLIC_
# Usar somente em Server Actions e Route Handlers
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# -----------------------------------------------
# Contato
# -----------------------------------------------
# Numero do WhatsApp no formato internacional sem espacos ou simbolos
NEXT_PUBLIC_WHATSAPP_NUMBER=5567993248550

# -----------------------------------------------
# Site
# -----------------------------------------------
# URL de producao do site (sem barra final)
NEXT_PUBLIC_SITE_URL=https://laertcostastudio.com.br
